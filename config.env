# ==============================
# MuseTalk Pipeline Config
# ==============================

# Puedes usar rutas relativas o absolutas.
# Windows ejemplo:
# VIDEO_PATH=C:\Users\vhgal\Videos\video.mp4
# AUDIO_PATH=C:\Users\vhgal\Videos\voz.wav

VIDEO_PATH=input/MATEO_01_lipsync_bancarrota.mp4
AUDIO_PATH=input/MATEO_01_lipsync_bancarrota.wav

# Carpeta de salida
OUTPUT_DIR=output
OUTPUT_NAME=final_lipsync.mp4

# Carpeta donde se clonará MuseTalk
MUSETALK_DIR=MuseTalk

# FFmpeg:
# - Si ffmpeg está en PATH, deja: ffmpeg
# - En Windows también puedes poner la carpeta bin:
#   FFMPEG_PATH=C:\ffmpeg\bin
FFMPEG_PATH=ffmpeg

# Versión recomendada: v15
# Valores: v15 o v1
VERSION=v15

# Ajuste de boca.
# 0 = default.
# positivo = boca más abierta.
# negativo = boca más cerrada.
BBOX_SHIFT=0

# Usar fp16 para ahorrar VRAM.
# true recomendado en RTX 4070.
USE_FLOAT16=true

# Carpeta de logs
LOG_DIR=logs
